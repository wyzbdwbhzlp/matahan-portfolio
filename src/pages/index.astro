    <!-- ========== 交互脚本 ========== -->
    <script>
        // ========== 1. 导航栏滚动效果 ==========
        const navbar = document.getElementById('navbar');
        let lastScroll = 0;

        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;
            if (currentScroll > 50) {
                navbar.classList.add('bg-ink-800/80', 'backdrop-blur-md', 'border-ink-500/50', 'shadow-lg');
                navbar.classList.remove('border-transparent');
            } else {
                navbar.classList.remove('bg-ink-800/80', 'backdrop-blur-md', 'border-ink-500/50', 'shadow-lg');
                navbar.classList.add('border-transparent');
            }
            lastScroll = currentScroll;
        });

        // ========== 2. 移动端菜单切换 ==========
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');

        menuToggle.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // 点击菜单项后自动关闭
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });

        // ========== 3. 滚动出现动画(IntersectionObserver) ==========
        const revealElements = document.querySelectorAll('.reveal');
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    // 触发技能条动画
                    if (entry.target.querySelector('.skill-bar-fill')) {
                        entry.target.querySelectorAll('.skill-bar-fill').forEach(bar => {
                            const width = bar.getAttribute('data-width');
                            // 延迟一点执行,让卡片先浮起
                            setTimeout(() => {
                                bar.style.width = width;
                            }, 300);
                        });
                    }
                }
            });
        }, { threshold: 0.15 });

        revealElements.forEach(el => {
            revealObserver.observe(el);
        });

        // 初始化技能条宽度为 0,等动画触发
        document.querySelectorAll('.skill-bar-fill').forEach(bar => {
            bar.style.width = '0%';
        });

        // ========== 4. 平滑滚动锚点 ==========
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const href = this.getAttribute('href');
                if (href === '#' || href === '#hero') return;
                e.preventDefault();
                const target = document.querySelector(href);
                if (target) {
                    const offset = 80; // 导航栏高度补偿
                    const top = target.getBoundingClientRect().top + window.pageYOffset - offset;
                    window.scrollTo({ top, behavior: 'smooth' });
                }
            });
        });

        // ========== 4.5 ANIMAL WELL 风格:随机故障触发 ==========
        // 持续故障层(scanlines / scanband / noise / vignette / chroma)已在 CSS 中自动循环
        // 这里负责:每 3-8 秒随机触发更强的"故障瞬间"
        const glitchEl = document.getElementById('crt-glitch');
        const tearEl = document.getElementById('crt-tear');

        function triggerGlitch(intensity = 'light') {
            // 1. 红色色差闪烁
            glitchEl.classList.add('active');
            setTimeout(() => glitchEl.classList.remove('active'), 600);

            // 2. 随机位置的水平撕裂线
            tearEl.style.top = (Math.random() * 100) + 'vh';
            tearEl.classList.add('active');
            setTimeout(() => tearEl.classList.remove('active'), 280);

            // 3. 强故障:整页短暂抖动 + 色相旋转
            if (intensity === 'heavy') {
                document.body.classList.add('glitch-jitter');
                setTimeout(() => document.body.classList.remove('glitch-jitter'), 320);
            }
        }

        // 随机故障调度器
        function scheduleNextGlitch() {
            // 3-8 秒之间随机下一次
            const delay = 3000 + Math.random() * 5000;
            setTimeout(() => {
                // 30% 概率是重故障
                const intensity = Math.random() < 0.3 ? 'heavy' : 'light';
                triggerGlitch(intensity);
                scheduleNextGlitch();
            }, delay);
        }

        // 页面加载后延迟 2 秒开始第一次,避免刚加载就故障
        setTimeout(() => {
            scheduleNextGlitch();
        }, 2000);

        // ========== 5. 终端打字机效果(循环) ==========
        const terminalPhrases = [
            'whoami',
            'echo "Game Designer"',
            'cat skills.json',
            'ls ./projects',
            'git status',
        ];
        let phraseIndex = 0;
        const terminalEl = document.querySelector('.terminal');
        const originalTerminalHTML = terminalEl.innerHTML;

        function runTerminalCycle() {
            const phrase = terminalPhrases[phraseIndex];
            let i = 0;
            // 重置显示
            terminalEl.innerHTML = `<span class="text-slate-500">$</span> <span class="text-neon typing-text"></span><span class="animate-blink text-neon ml-1">▊</span>`;
            const typingTarget = terminalEl.querySelector('.typing-text');

            const typeInterval = setInterval(() => {
                if (i < phrase.length) {
                    typingTarget.textContent += phrase[i];
                    i++;
                } else {
                    clearInterval(typeInterval);
                    // 停 2 秒,清空,换下一句
                    setTimeout(() => {
                        phraseIndex = (phraseIndex + 1) % terminalPhrases.length;
                        runTerminalCycle();
                    }, 2500);
                }
            }, 80);
        }

        // 页面加载后启动终端循环
        window.addEventListener('load', () => {
            setTimeout(runTerminalCycle, 1000);
        });

        // ========== 6. 控制台彩蛋(Easter Egg) ==========
        console.log(
            '%c⚡ Wu Haohan — Game Designer & Indie Dev',
            'color: #00ff88; font-size: 18px; font-weight: bold; text-shadow: 0 0 10px #00ff88;'
        );
        console.log(
            '%c>> 想一起做点酷的项目?联系: wuhaohan@example.com',
            'color: #ff7a45; font-size: 12px;'
        );
    </script>
