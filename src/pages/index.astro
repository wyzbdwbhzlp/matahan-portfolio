                        <div class="flex flex-wrap gap-2 mb-3">
                            <span class="tag tag-ember" data-i18n="proj1.tag1">2D 解密</span>
                            <span class="tag" data-i18n="proj1.tag2">TapTap 9.9</span>
                            <span class="tag" data-i18n="proj1.tag3">聚光灯 TOP50</span>
