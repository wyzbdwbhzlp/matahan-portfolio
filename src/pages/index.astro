<body class="relative overflow-x-hidden">
    <!-- ========== 自定义系统光标(桌面端) ========== -->
    <div class="cursor-crosshair" id="cursor-crosshair" aria-hidden="true">
        <div class="cross-line" style="position:absolute; top:50%; left:0; width:100%; height:1px; background:#4ade80;"></div>
        <div class="cross-line" style="position:absolute; left:50%; top:0; width:1px; height:100%; background:#4ade80;"></div>
        <div class="cross-center" style="position:absolute; top:50%; left:50%; width:6px; height:6px; background:#4ade80; transform:translate(-50%,-50%); box-shadow:0 0 8px #4ade80;"></div>
        <span class="click-label">CLICK</span>
    </div>
    <div id="cursor-trail-container" aria-hidden="true"></div>

    <!-- ========== Konami 彩蛋:像素雪崩画布 ========== -->
    <canvas id="matrix-rain" aria-hidden="true"></canvas>
    <div class="konami-banner" id="konami-banner" aria-hidden="true">
        <div class="title">KONAMI CODE</div>
        <div class="subtitle">// developer_mode_unlocked</div>
    </div>

    <!-- ========== 1-bit Adventure 小游戏全屏层 ========== -->
    <div id="adventure-game" class="adventure-game" aria-hidden="true">
        <div class="adventure-hud">
            <span class="adventure-score">SCORE <b id="adv-score">0</b></span>
            <span class="adventure-time">TIME <b id="adv-time">30</b></span>
            <span class="adventure-hint">← → / A D · SPACE 跳 · ESC 退出</span>
        </div>
        <canvas id="adventure-canvas" width="640" height="360"></canvas>
        <div class="adventure-overlay" id="adventure-start">
            <div class="adventure-title">▶ 1-BIT ADVENTURE</div>
            <div class="adventure-sub">按 SPACE 开始 · 跳雪堆 · 躲极光球 · 捡金币</div>
            <div class="adventure-keys">← → 移动 · SPACE 跳跃 · ESC 退出</div>
        </div>
        <div class="adventure-overlay hidden" id="adventure-end">
            <div class="adventure-title" id="adv-end-title">GAME OVER</div>
            <div class="adventure-sub">SCORE <b id="adv-final-score">0</b></div>
            <div class="adventure-keys">SPACE 重玩 · ESC 退出</div>
        </div>
    </div>
    <div class="konami-hint" id="konami-hint" aria-hidden="true">
        Try: <kbd>↑</kbd><kbd>↑</kbd><kbd>↓</kbd><kbd>↓</kbd><kbd>←</kbd><kbd>→</kbd><kbd>←</kbd><kbd>→</kbd><kbd>B</kbd><kbd>A</kbd>
    </div>

    <!-- ========== CRT 扫描线 + 故障渲染覆盖层 ========== -->
    <div class="crt-scanlines" aria-hidden="true"></div>
    <div class="crt-scanband" aria-hidden="true"></div>
    <div class="crt-noise" aria-hidden="true"></div>
    <div class="crt-vignette" aria-hidden="true"></div>
    <div class="crt-glitch" id="crt-glitch" aria-hidden="true"></div>
    <div class="crt-tear" id="crt-tear" aria-hidden="true"></div>

    <div class="scanline"></div>

