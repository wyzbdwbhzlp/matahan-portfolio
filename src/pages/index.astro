    <!-- ========== 核心独立游戏作品 Selected Projects ========== -->
    <section id="projects" class="relative py-24 md:py-32 bg-paper-50/50">
        <div class="max-w-6xl mx-auto px-6">
            <div class="mb-16 reveal">
                <div class="flex items-center gap-3 mb-3">
