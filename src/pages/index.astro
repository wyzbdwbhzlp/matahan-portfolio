                <!-- 项目二:《库鲁绿洲》Kuru Oasis -->
                <div class="card-3d">
                    <article class="glass-card hover-dream p-6 md:p-8 group reveal card-3d-inner relative overflow-hidden" style="transition-delay: 0.1s;">
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-ink-700 rounded-none animate-pulse"></span>
                                <span class="text-xs text-ink-500 font-mono">PROJECT_02.exe</span>
                            </div>
                            <span class="text-xs text-ink-500 font-mono" data-i18n="proj2.status">DEV</span>
                        </div>

                        <div class="relative h-44 mb-6 border-4 border-ink-900 overflow-hidden pixel-thumb flex items-center justify-center">
                            <div class="relative z-10 text-center">
                                <div class="font-pixel text-2xl text-ink-900 mb-3">🌿</div>
                                <div class="text-[9px] text-aurora-green font-pixel">[ IDLE_GAME ]</div>
                            </div>
                            <span class="absolute top-2 left-2 text-[10px] text-ink-900 font-pixel">┌─</span>
                            <span class="absolute top-2 right-2 text-[10px] text-ink-900 font-pixel">─┐</span>
                            <span class="absolute bottom-2 left-2 text-[10px] text-ink-900 font-pixel">└─</span>
                            <span class="absolute bottom-2 right-2 text-[10px] text-ink-900 font-pixel">─┘</span>
                        </div>

                        <div class="flex flex-wrap gap-2 mb-3">
                            <span class="tag tag-ember" data-i18n="proj2.tag1">2D 休闲放置</span>
                            <span class="tag" data-i18n="proj2.tag2">独立开发中</span>
                            <span class="tag" data-i18n="proj2.tag3">治愈系</span>
                        </div>

                        <h3 class="font-mono font-bold text-lg sm:text-xl text-ink-900 mb-3 group-hover:text-aurora-green transition-colors uppercase tracking-tight">
                            <span data-i18n="proj2.title">《库鲁绿洲》</span> <span class="text-ink-500 text-lg">/ Kuru Oasis</span>
